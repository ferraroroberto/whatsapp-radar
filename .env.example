# WhatsApp Radar — example environment. Copy to .env (ignored) and adjust per host.
# None of these contain secrets in this spike; .env stays ignored regardless.

# SQLite path for local state (default: data/whatsapp-radar.sqlite3, ignored).
WR_DB_PATH=data/whatsapp-radar.sqlite3

# Connector implementation: fixture (default). The real linked-device connector is deferred.
WR_CONNECTOR=fixture

# Classifier: stub (deterministic, default, no network) | hub (real local-llm-hub call).
WR_CLASSIFIER=stub

# local-llm-hub endpoint, used only when WR_CLASSIFIER=hub.
WR_HUB_BASE_URL=http://127.0.0.1:8000
WR_HUB_MODEL=agentic_light
