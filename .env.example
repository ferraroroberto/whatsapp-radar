# WhatsApp Radar — example environment. Copy to .env (ignored) and adjust per host.
# None of these contain secrets in this spike; .env stays ignored regardless.

# SQLite path for local state (default: data/whatsapp-radar.sqlite3, ignored).
WR_DB_PATH=data/whatsapp-radar.sqlite3

# Connector implementation: fixture (default, offline) | linked_device (real WhatsApp via the
# Node sidecar — run sidecar/ separately and pair a device first; see docs/bootstrapping.md).
WR_CONNECTOR=fixture

# Directory where the Node sidecar writes its buffer (ignored). Default shown.
WR_LINKED_DEVICE_DIR=data/linked_device

# Auto-relaunch the sidecar as the first step of a live scan/resync if its
# heartbeat is stale (the process died but the device is still paired). Default
# on; set to 0/false to instead abort loudly without trying to self-heal.
WR_SIDECAR_AUTOSTART=1
# Override how the sidecar process is launched (default: `node` on PATH).
# WR_NODE_BIN=node
# How often (seconds) the tray's keep-alive supervisor re-checks the sidecar and
# relaunches it if the process died. Linked-device only; honours WR_SIDECAR_AUTOSTART.
# WR_SIDECAR_SUPERVISE_SECONDS=90

# Settled-buffer gate (#73): before a live scan reads the buffer it waits until the
# buffer has stopped growing for WR_SYNC_SETTLE_SECONDS (history backfill finished),
# hard-capped at WR_SYNC_SETTLE_TIMEOUT, so a scan that coincides with a reconnect
# can't read early and skip messages. Set WR_SYNC_SETTLE_SECONDS=0 to disable.
WR_SYNC_SETTLE_SECONDS=12
WR_SYNC_SETTLE_TIMEOUT=90

# Classifier: stub (deterministic keyword, default, no network) | hub (LLM via local-llm-hub)
# | cascade (multilingual keyword prefilter that gates an LLM call — recommended for real use).
WR_CLASSIFIER=stub

# local-llm-hub endpoint + model, used when WR_CLASSIFIER=hub or cascade.
# Default is claude_sonnet: it answers with JSON directly. Avoid reasoning models
# (e.g. agentic_light) whose <think> trace can overrun the token budget and yield
# no parseable JSON.
WR_HUB_BASE_URL=http://127.0.0.1:8000
WR_HUB_MODEL=claude_sonnet
# Output token budget per classification call. Raise it for a reasoning model so
# its <think> trace doesn't truncate before the JSON; a truncated call is recorded
# as 'llm_truncated' in the audit trace (not a generic contract error).
WR_HUB_MAX_TOKENS=8192
# Max characters of the message delta sent in one prompt. Caps a whole-history scan
# so a single request can't blow the model's context window (oldest messages dropped).
WR_HUB_MAX_PROMPT_CHARS=24000

# Notification delivery: none (default, records skipped) | telegram.
WR_NOTIFIER=none

# Telegram delivery secrets (used only when WR_NOTIFIER=telegram). These ARE secrets —
# .env is ignored; never commit real values. See docs/bootstrapping.md step 4 to obtain them.
# Canonical home since Step 3 is the gitignored config/webapp_config.json
# (telegram_bot_token / telegram_chat_id); these env vars still override it.
WR_TELEGRAM_BOT_TOKEN=
WR_TELEGRAM_CHAT_ID=
