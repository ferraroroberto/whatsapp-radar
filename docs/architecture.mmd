%% docs/architecture.mmd — whatsapp-radar's own internal structure.
%% Hand-authored, not generated (unlike fleet-config's mechanically-aggregated
%% fleet-wide `/system-map`) — this repo's own internal shape is semantic and
%% can't be crawled the same way. Update this diagram in the same PR as any
%% material structural change (a connector added, a pipeline stage moved, a
%% router split) — same anti-staleness contract as this repo's `.fleet.toml`
%% `description` field. See fleet-config's `CLAUDE.md` ("Every repo carries a
%% `.fleet.toml`") for the general convention (ferraroroberto/fleet-config#256).

flowchart TB
  subgraph entry["Entry points"]
    LAUNCHER["launcher.py / wr.bat"]
    TRAYBAT["tray.bat / webapp.bat"]
  end

  subgraph cli["app/cli/main.py — argparse CLI"]
    CLICMDS["status · ingest · chats · monitor · ignore ·\nreview · scan · notify · resync · reprocess · gmail-survey ·\ncalendar-scan · traffic-check · tray"]
  end
  LAUNCHER --> CLICMDS

  subgraph tray["app/tray/tray.py — pystray surface"]
    TRAYPY["owns webapp lifecycle + sidecar keep-alive\n+ optional cloudflared tunnel"]
    SINGLEINST["single_instance.py"]
    CLOUDFLARED["cloudflared_proc.py"]
  end
  TRAYBAT --> TRAYPY
  TRAYPY --> SINGLEINST
  TRAYPY --> CLOUDFLARED

  subgraph webapp["app/webapp/ — FastAPI + vanilla-JS PWA (:8455)"]
    SERVER["server.py — app assembly, static mount"]
    MANAGER["manager.py — WebappManager (start/stop/restart)"]
    MIDDLEWARE["middleware.py — bearer-token gate"]
    RUNS["runs.py — spawns CLI pieces, streams output"]
    ROUTERS["routers/: dashboard · chats · execution ·\nconfig · sidecar · auth · webauthn · audit · family · misc"]
  end
  TRAYPY --> MANAGER
  MANAGER --> SERVER
  SERVER --> MIDDLEWARE
  SERVER --> ROUTERS
  ROUTERS --> RUNS

  subgraph pipeline["src/analysis/pipeline.py — scan (the one callable App Launcher's Jobs tab fires)"]
    SCAN["scan(mode: live | dry_run)"]
    TRANSCRIBE["transcription.py — voice notes -> hub Whisper"]
    KEYWORDS["keywords.py — Stage 1 prefilter"]
    TRIPWIRE["tripwire.py — bounded Stage-1-only scan\nof discovered chats; no classifier"]
    CLASSIFIER["classifier.py — Stage 2 (stub | hub | cascade)"]
    CONTRACT["contract.py — parse_analysis / AnalysisResult"]
    REVIEW["review.py — cursor advance + alert memory"]
    SURVEY["gmail_survey.py — bounded whitelist survey\n-> generic Gmail taxonomy/rules"]
  end
  CLICMDS --> SCAN
  RUNS --> SCAN
  SCAN --> TRANSCRIBE
  SCAN --> KEYWORDS
  SCAN --> TRIPWIRE
  SCAN --> CLASSIFIER
  CLASSIFIER --> CONTRACT
  SCAN --> REVIEW
  CLICMDS --> SURVEY

  subgraph connector["src/connector/ — read-only connector boundary"]
    CFACTORY["factory.py — build_connectors(config)\nsource-tagged bindings"]
    FANOUT["db/sync.py — per-source fan-out\nisolation + sync_log"]
    FIXTURE["fixture.py — deterministic offline fixture"]
    LINKED["linked_device.py — reads sidecar NDJSON buffer"]
    GMAIL["gmail.py — thin application adapter"]
    SIDECARPY["sidecar.py — Node lifecycle supervisor\n(wait/relaunch, never kill)"]
    PREFLIGHT["preflight.py — abort loud if source is down"]
  end
  SCAN --> CFACTORY
  CFACTORY --> FANOUT
  CFACTORY --> FIXTURE
  CFACTORY --> LINKED
  CFACTORY --> GMAIL
  SCAN --> PREFLIGHT
  TRAYPY -->|keep-alive supervise| SIDECARPY
  LINKED --> SIDECARPY

  subgraph gmailcore["gmail_readonly/ — reusable framework-neutral component"]
    GMAILCORE["OAuth + token refresh\nwhitelist + paginated search\nsender discovery (last N days)\nmetadata/count + MIME normalization"]
  end
  GMAIL --> GMAILCORE
  SURVEY --> GMAILCORE

  subgraph family["src/family/ — deterministic scheduled checks (#160, no LLM)"]
    FRULES["rules.py — pure classification / origin / dedup / conflicts"]
    FTRAFFIC["traffic_check.py — commute -> Routes -> alert"]
    FCAL["calendar_scan.py — conflict scan + decision trace + daily summary"]
    FSOURCE["calendar_source.py — events per person"]
    FDEDUP["dedup.py — data/family/ alert log"]
  end
  CLICMDS --> FTRAFFIC
  CLICMDS --> FCAL
  FTRAFFIC --> FRULES
  FCAL --> FRULES
  FTRAFFIC --> FSOURCE
  FCAL --> FSOURCE
  FTRAFFIC --> FDEDUP
  FTRAFFIC --> ALERT
  FCAL --> ALERT
  ROUTERS -->|/api/family| CONFIGPY
  ROUTERS -->|/api/family recent runs #163| STORE
  CLICMDS -->|family run rows #163| STORE
  RUNS --> FTRAFFIC
  RUNS --> FCAL

  subgraph calcore["calendar_readonly/ + src/traffic/ — Google read clients (#160)"]
    CALCLIENT["calendar_readonly — OAuth + Calendar v3 read"]
    ROUTESCLIENT["src/traffic — Routes API v2 computeRoutes"]
  end
  FSOURCE --> CALCLIENT
  FTRAFFIC --> ROUTESCLIENT

  subgraph presence["src/presence/ — live phone location (#169, read-only)"]
    PCLIENT["client.py — get_location: resolve person,\nderive freshness from last_seen (never trust 'stale'),\nrefresh when stale; typed result, coords never persisted"]
  end
  FTRAFFIC -->|live origin, fallback to calendar inference| PCLIENT
  PCLIENT -->|GET /api/presence + POST /refresh| HOMEAUTO["home-automation presence API\n127.0.0.1:8447 (loopback bypasses bearer)"]

  subgraph sidecarnode["sidecar/index.js — Node/Baileys (external process)"]
    BAILEYS["read-only WhatsApp linked device\nwrites NDJSON buffer + status.json heartbeat\nunder gitignored data/linked_device/"]
  end
  SIDECARPY -->|spawn / heartbeat poll| BAILEYS
  LINKED -->|read buffer| BAILEYS

  subgraph db["src/db/ — SQLite store"]
    STORE["store.py — re-export facade over\nconnection/chats/messages/runs/dashboard/\nsync_log/tripwire/reprocess_support/retention.py"]
    SYNC["sync.py — ingest_chats / resync\n+ Gmail unmonitored-sender retention prune"]
    REPROCESS["reprocess.py — full rebuild, preserves operator state"]
  end
  FANOUT --> SYNC
  SYNC --> STORE
  REPROCESS --> STORE
  REVIEW --> STORE
  SCAN --> STORE
  ROUTERS --> STORE

  subgraph report["src/report/digest.py"]
    DIGEST["build_digest — one consolidated Digest per run"]
  end
  SCAN --> DIGEST

  subgraph notify["src/notify/"]
    NFACTORY["factory.py — build_notifier(none | telegram)"]
    DELIVERY["delivery.py — deliver_digest"]
    ALERT["alert.py — send_alert (preflight/pipeline failures)"]
    TELEGRAM["telegram.py — TelegramNotifier"]
  end
  DIGEST --> DELIVERY
  DELIVERY --> NFACTORY
  NFACTORY --> TELEGRAM
  PREFLIGHT --> ALERT
  TRIPWIRE -->|opt-in weekly nudge| ALERT
  ALERT --> NFACTORY

  subgraph config["src/config.py + config/"]
    CONFIGPY["Config — default.json -> local.json -> WR_* env/.env"]
    DEFAULTJSON["config/default.json (committed)"]
    LOCALJSON["config/local.json + webapp_config.json\n(gitignored secrets/local overrides)"]
  end
  CLICMDS --> CONFIGPY
  SCAN --> CONFIGPY
  ROUTERS --> CONFIGPY
  CONFIGPY --> DEFAULTJSON
  CONFIGPY --> LOCALJSON

  subgraph ext["External dependencies"]
    HUB["local-llm-hub (127.0.0.1:8000)\nclassification (claude_sonnet) + Whisper transcription"]
    TELEGRAMAPI["Telegram Bot API — digest delivery"]
    APPLAUNCHER["App Launcher — Jobs (scan/resync/reprocess/\ncalendar-scan/traffic-check) + Apps tab (webapp URL)"]
    TAILSCALE["Tailscale — TLS for the tunnel"]
    FFMPEG["ffmpeg — voice-note transcode (OGG -> WAV/MP3)"]
    GMAILAPI["Gmail API — gmail.readonly\nOAuth token under auth/gmail/"]
    CALAPI["Google Calendar API — calendar.readonly\nOAuth token under auth/calendar/"]
    ROUTESAPI["Google Routes API v2 — API key"]
  end
  CLASSIFIER -->|hub / cascade mode| HUB
  SURVEY -->|one local analysis pass| HUB
  TRANSCRIBE --> HUB
  TELEGRAM --> TELEGRAMAPI
  APPLAUNCHER --> CLICMDS
  SERVER --> TAILSCALE
  TRANSCRIBE --> FFMPEG
  GMAILCORE --> GMAILAPI
  CALCLIENT --> CALAPI
  ROUTESCLIENT --> ROUTESAPI
